import { Router } from 'express';
import { createAgent, updateAgent, deleteAgent, getAgent } from './agentController';

const managerRouter = Router();

// Route to create a new agent
managerRouter.post('/agents', createAgent);

// Route to update an existing agent
managerRouter.put('/agents/:id', updateAgent);

// Route to delete an agent
managerRouter.delete('/agents/:id', deleteAgent);

// Route to get an agent by ID
managerRouter.get('/agents/:id', getAgent);

export default managerRouter;